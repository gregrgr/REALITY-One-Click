NODE_ROLE=single

# single/relay panel and subscription settings
PANEL_DOMAIN=panel.example.com
ACME_EMAIL=admin@example.com
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password
PUBLIC_HOST=
XRAY_PUBLIC_PORT=443
XRAY_LISTEN=0.0.0.0
XRAY_PORT=443
PANEL_HTTPS_PORT=8443
# Set this to the actual SSH port on the current VPS.
SSH_PORT=22

# relay -> egress settings
EGRESS_TAILSCALE_IP=
EGRESS_BACKEND_PORT=10808
EGRESS_BACKEND_PROTOCOL=socks
TAILSCALE_REQUIRED=yes

# panel exit latency probe
LATENCY_PROBE_URL=https://www.gstatic.com/generate_204
LATENCY_IP_CHECK_URL=https://api.ipify.org
LATENCY_TIMEOUT_SECONDS=5
LATENCY_CACHE_SECONDS=30

# Clash rule-providers based on Loyalsoldier/clash-rules
CLASH_RULE_PROVIDERS_ENABLED=yes
CLASH_RULE_PROVIDER_BASE_URL=https://cdn.jsdelivr.net/gh/Loyalsoldier/clash-rules@release
CLASH_RULE_PROVIDER_INTERVAL=86400

# egress settings
EGRESS_BACKEND_LISTEN=

# optional certificate mode for single/relay
ACME_CHALLENGE=http
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_PROPAGATION_SECONDS=60
